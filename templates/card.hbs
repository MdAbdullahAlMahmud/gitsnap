<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>{{repoName}} — gitsnap</title>
  <style>{{{styles}}}</style>
  {{#if primaryLanguage}}
  <style>
    :root {
      --lang-gradient: linear-gradient(90deg, {{primaryLanguage.color}}cc 0%, {{primaryLanguage.color}}66 60%, transparent 100%);
    }
    .avatar-ring { background: linear-gradient(135deg, {{primaryLanguage.color}}, {{primaryLanguage.color}}88); }
    .card-accent  { background: linear-gradient(90deg, {{primaryLanguage.color}} 0%, {{primaryLanguage.color}}99 40%, {{primaryLanguage.color}}33 100%); }
  </style>
  {{/if}}
</head>
<body class="{{theme}}">
<div class="card">

  <!-- Top accent bar -->
  <div class="card-accent"></div>

  <!-- Two-column body -->
  <div class="card-body">

    <!-- ── LEFT ── -->
    <div class="left">

      <!-- Header -->
      <div class="header">
        <div class="avatar-wrap">
          <div class="avatar-ring">
            {{#if github.avatarUrl}}
              <img class="avatar" src="{{github.avatarUrl}}" alt="{{github.owner}}" />
            {{else}}
              <div class="avatar-placeholder">⚡</div>
            {{/if}}
          </div>
        </div>

        <div class="header-meta">
          {{#if github.owner}}
            <div class="repo-owner">{{github.owner}}</div>
          {{/if}}
          <div class="repo-name">{{repoName}}</div>
          {{#if github.description}}
            <div class="repo-description">{{github.description}}</div>
          {{/if}}
          <div class="badges">
            {{#if packageVersion}}
              <span class="badge version">v{{packageVersion}}</span>
            {{/if}}
            {{#if github.license}}
              <span class="badge license">{{github.license}}</span>
            {{/if}}
            <span class="badge branch">⎇ {{defaultBranch}}</span>
          </div>
        </div>
      </div>

      <!-- Language bar -->
      {{#if languages.length}}
      <div class="lang-section">
        <div class="lang-bar">
          {{#each languages}}
            <div class="lang-seg" style="width:{{percentage}}%;background:{{color}};"></div>
          {{/each}}
        </div>
        <div class="lang-labels">
          {{#each languages}}
            <span class="lang-label">
              <span class="lang-dot" style="background:{{color}};"></span>
              <span class="lang-name">{{language}}</span>
              <span class="lang-pct">{{formatPercent percentage}}%</span>
            </span>
          {{/each}}
        </div>
      </div>
      {{/if}}

      <!-- Recent commits -->
      {{#if recentCommits.length}}
      <div class="commits">
        <div class="section-label">Recent commits</div>
        {{#each recentCommits}}
          <div class="commit">
            <span class="commit-hash">{{hash}}</span>
            <span class="commit-msg">{{message}}</span>
            <span class="commit-date">{{relativeDate}}</span>
          </div>
        {{/each}}
      </div>
      {{/if}}

    </div><!-- /left -->

    <!-- ── RIGHT ── -->
    <div class="right">

      <!-- GitHub stat chips -->
      {{#if github}}
      <div class="gh-stats">
        <div class="gh-chip">
          <span class="gh-chip-val">{{formatNum github.stars}}</span>
          <span class="gh-chip-label"><span class="gh-chip-icon">★</span> Stars</span>
        </div>
        <div class="gh-chip">
          <span class="gh-chip-val">{{formatNum github.forks}}</span>
          <span class="gh-chip-label"><span class="gh-chip-icon">⑂</span> Forks</span>
        </div>
        <div class="gh-chip">
          <span class="gh-chip-val">{{github.openIssues}}</span>
          <span class="gh-chip-label"><span class="gh-chip-icon">◎</span> Issues</span>
        </div>
        <div class="gh-chip">
          <span class="gh-chip-val">{{contributorCount}}</span>
          <span class="gh-chip-label"><span class="gh-chip-icon">◈</span> Contributors</span>
        </div>
      </div>
      {{/if}}

      <!-- Repo info -->
      <div class="info-grid">
        <div class="info-row">
          <span class="info-icon">📁</span>
          <span class="info-val">{{formatNum totalFiles}}</span>
          <span>files</span>
          <span class="info-sep">·</span>
          <span class="info-val">{{totalSizeFormatted}}</span>
        </div>
        <div class="info-row">
          <span class="info-icon">📝</span>
          <span class="info-val">{{formatNum totalCommits}}</span>
          <span>commits</span>
          {{#if ageFormatted}}
            <span class="info-sep">·</span>
            <span>{{ageFormatted}}</span>
          {{/if}}
        </div>
        {{#if packageManager}}
        <div class="info-row">
          <span class="info-icon">📦</span>
          <span class="info-val">{{packageManager}}</span>
          {{#if dependencyCount}}
            <span class="info-sep">·</span>
            <span class="info-val">{{dependencyCount}}</span>
            <span>dependencies</span>
          {{/if}}
        </div>
        {{/if}}
        {{#unless github}}
        <div class="info-row">
          <span class="info-icon">👤</span>
          <span class="info-val">{{contributorCount}}</span>
          <span>contributors</span>
        </div>
        {{/unless}}
      </div>

      <!-- Activity sparkline -->
      {{#if weeklyActivity.length}}
      <div class="sparkline-wrap">
        <div class="section-label">Commit activity · last 24 weeks</div>
        <div class="sparkline">
          {{#each weeklyActivity}}
            <div class="spark-bar level-{{level}}" title="{{count}} commits"></div>
          {{/each}}
        </div>
      </div>
      {{/if}}

      <!-- Topics -->
      {{#if github.topics.length}}
      <div>
        <div class="section-label">Topics</div>
        <div class="topics">
          {{#each github.topics}}
            <span class="topic">{{this}}</span>
          {{/each}}
        </div>
      </div>
      {{/if}}

    </div><!-- /right -->
  </div><!-- /card-body -->

  <!-- Footer -->
  <div class="footer">
    <div class="footer-brand">
      <span class="footer-brand-dot"></span>
      gitsnap
    </div>
    <div class="footer-right">
      {{#if primaryLanguage}}
      <div class="footer-primary-lang">
        <span class="lang-dot" style="background:{{primaryLanguage.color}};width:8px;height:8px;border-radius:50%;display:inline-block;"></span>
        {{primaryLanguage.language}}
      </div>
      {{/if}}
      <span class="footer-date">{{formatDate generatedAt}}</span>
    </div>
  </div>

</div>
</body>
</html>
