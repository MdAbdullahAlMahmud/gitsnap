{
  "name": "gitcard",
  "version": "1.0.0",
  "description": "Generate beautiful visual snapshot cards of git repositories",
  "type": "module",
  "main": "./dist/cli.js",
  "bin": {
    "gitcard": "./bin/gitcard.js"
  },
  "files": [
    "dist",
    "bin",
    "templates",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/ --ext .ts",
    "lint:fix": "eslint src/ tests/ --ext .ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "release": "changeset publish",
    "prepare": "husky"
  },
  "keywords": [
    "git",
    "screenshot",
    "repository",
    "snapshot",
    "card",
    "cli",
    "visualization",
    "github",
    "stats"
  ],
  "author": "Abdullah <mmunna864@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MdAbdullahAlMahmud/gitcard.git"
  },
  "homepage": "https://github.com/MdAbdullahAlMahmud/gitcard#readme",
  "bugs": {
    "url": "https://github.com/MdAbdullahAlMahmud/gitcard/issues"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "handlebars": "^4.7.8",
    "ora": "^9.3.0",
    "puppeteer": "^24.40.0",
    "simple-git": "^3.33.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@commitlint/cli": "^19.2.1",
    "@commitlint/config-conventional": "^19.2.0",
    "@eslint/js": "^9.39.4",
    "@types/handlebars": "^4.1.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "tsup": "^8.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.57.2",
    "vitest": "^3.0.0"
  }
}
